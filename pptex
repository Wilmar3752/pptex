#!/usr/bin/env bash
set -euo pipefail

PPTEX_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_NAME="pptex"
IMAGE_TAG="latest"

# Prevent Git Bash on Windows from converting Unix paths in docker -v flags
export MSYS_NO_PATHCONV=1

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${BLUE}[pptex]${NC} $*"; }
success() { echo -e "${GREEN}[pptex]${NC} $*"; }
warn()    { echo -e "${YELLOW}[pptex]${NC} $*"; }
error()   { echo -e "${RED}[pptex] Error:${NC} $*" >&2; exit 1; }

usage() {
    echo -e "${BOLD}pptex${NC} — LaTeX with Docker, zero friction"
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    echo "  pptex <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS${NC}"
    echo "  new     slides <name>        Create a new presentation  → slides/<name>/"
    echo "  new     report <name>        Create a new report         → reports/<name>/"
    echo "  compile slides <name>        Compile slides/<name>/main.tex"
    echo "  compile reports <name>       Compile reports/<name>/main.tex"
    echo "  compile <file.tex>           Compile any .tex file directly"
    echo "  watch   slides <name>        Watch and recompile on changes"
    echo "  watch   reports <name>       Watch reports/<name>/main.tex"
    echo "  watch   <file.tex>           Watch any .tex file directly"
    echo "  list    [slides|reports]     List all projects"
    echo "  clean   slides <name>        Remove auxiliary files for a project"
    echo "  clean   reports <name>       Remove auxiliary files for a project"
    echo "  clean                        Remove auxiliary files in all projects"
    echo "  shell                        Open an interactive shell in the container"
    echo "  build                        Build (or rebuild) the Docker image"
    echo ""
    echo -e "${BOLD}OPTIONS (compile / watch)${NC}"
    echo "  -e, --engine <engine>        pdflatex | xelatex | lualatex  (default: xelatex)"
    echo "  -b, --biber                  Run biber for bibliography (biblatex)"
    echo "  -o, --output-dir <dir>       Output directory for the PDF"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo "  pptex build"
    echo "  pptex new slides congreso"
    echo "  pptex new slides curso_estadistica"
    echo "  pptex compile slides congreso"
    echo "  pptex compile slides congreso --engine lualatex --biber"
    echo "  pptex watch slides congreso"
    echo "  pptex list"
    echo "  pptex clean slides congreso"
}

# ─── Image management ────────────────────────────────────────────────────────

build_image() {
    info "Building Docker image ${IMAGE_NAME}:${IMAGE_TAG} ..."
    docker build -t "${IMAGE_NAME}:${IMAGE_TAG}" "${PPTEX_DIR}"
    success "Image built successfully."
}

ensure_image() {
    if ! docker image inspect "${IMAGE_NAME}:${IMAGE_TAG}" &>/dev/null; then
        warn "Docker image not found. Building it now (first time only — this may take a few minutes)..."
        build_image
    fi
}

# ─── Project resolution ──────────────────────────────────────────────────────
# Given ("slides", "congreso") → returns absolute path to main.tex

resolve_project() {
    local type="$1"
    local name="$2"

    # Normalize: "report" → "reports", "slide" → "slides"
    case "$type" in
        slide|slides)       type="slides"  ;;
        report|reports)     type="reports" ;;
        presentation)       type="slides"  ;;
        *) error "Unknown project type '${type}'. Use: slides | reports" ;;
    esac

    local project_dir="${PPTEX_DIR}/${type}/${name}"
    [[ ! -d "$project_dir" ]] && error "Project not found: ${type}/${name}\n  Run 'pptex list' to see available projects."

    local main="${project_dir}/main.tex"
    [[ ! -f "$main" ]] && error "No main.tex found in ${type}/${name}/"

    echo "$main"
}

# Parse positional args and print the resolved .tex file path to stdout.
# Accepts:
#   ("slides", "congreso")        → resolve project shorthand
#   ("slides/congreso/main.tex")  → use directly
resolve_file() {
    local positional=("$@")

    if [[ ${#positional[@]} -eq 2 ]]; then
        resolve_project "${positional[0]}" "${positional[1]}"
    elif [[ ${#positional[@]} -eq 1 ]]; then
        [[ ! -f "${positional[0]}" ]] && error "File not found: ${positional[0]}"
        echo "${positional[0]}"
    else
        error "Specify a project or file.\n  Examples:\n    pptex compile slides congreso\n    pptex compile slides/congreso/main.tex"
    fi
}

# ─── Compile ─────────────────────────────────────────────────────────────────

cmd_compile() {
    local engine="xelatex"
    local use_biber=false
    local output_dir=""
    local positional=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -e|--engine)     engine="$2";      shift 2 ;;
            -b|--biber)      use_biber=true;   shift   ;;
            -o|--output-dir) output_dir="$2";  shift 2 ;;
            -*)              error "Unknown option: $1" ;;
            *)               positional+=("$1"); shift  ;;
        esac
    done

    local file
    file="$(resolve_file "${positional[@]}")"

    local abs_file
    abs_file="$(cd "$(dirname "$file")" && pwd)/$(basename "$file")"
    local src_dir
    src_dir="$(dirname "$abs_file")"
    local basename
    basename="$(basename "$abs_file" .tex)"

    local out_dir="${output_dir:-$src_dir}"
    [[ "$output_dir" ]] && mkdir -p "$out_dir" && out_dir="$(cd "$out_dir" && pwd)"

    local latexmk_args=("-${engine}" "-interaction=nonstopmode" "-file-line-error" "-synctex=1")
    [[ "$use_biber" == true ]] && latexmk_args+=("-biber")
    [[ "$out_dir" != "$src_dir" ]] && latexmk_args+=("-outdir=/out")

    ensure_image

    info "Compiling ${basename}.tex with ${engine}${use_biber:+ + biber}..."

    local docker_cmd="latexmk ${latexmk_args[*]} '${basename}.tex'"

    if [[ "$out_dir" != "$src_dir" ]]; then
        docker run --rm \
            -v "${src_dir}:/workspace" \
            -v "${out_dir}:/out" \
            -w /workspace \
            "${IMAGE_NAME}:${IMAGE_TAG}" \
            bash -c "$docker_cmd"
    else
        docker run --rm \
            -v "${src_dir}:/workspace" \
            -w /workspace \
            "${IMAGE_NAME}:${IMAGE_TAG}" \
            bash -c "$docker_cmd"
    fi

    success "Done! PDF: ${out_dir}/${basename}.pdf"
}

# ─── Watch ───────────────────────────────────────────────────────────────────

cmd_watch() {
    local engine="xelatex"
    local use_biber=false
    local positional=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -e|--engine)  engine="$2";    shift 2 ;;
            -b|--biber)   use_biber=true; shift   ;;
            -*)           error "Unknown option: $1" ;;
            *)            positional+=("$1"); shift ;;
        esac
    done

    local file
    file="$(resolve_file "${positional[@]}")"

    local abs_file
    abs_file="$(cd "$(dirname "$file")" && pwd)/$(basename "$file")"
    local src_dir
    src_dir="$(dirname "$abs_file")"
    local basename
    basename="$(basename "$abs_file" .tex)"

    local latexmk_args=("-${engine}" "-interaction=nonstopmode" "-pvc" "-synctex=1")
    [[ "$use_biber" == true ]] && latexmk_args+=("-biber")

    ensure_image

    info "Watching ${basename}.tex (press Ctrl+C to stop)..."

    docker run --rm -it \
        -v "${src_dir}:/workspace" \
        -w /workspace \
        "${IMAGE_NAME}:${IMAGE_TAG}" \
        latexmk "${latexmk_args[@]}" "${basename}.tex"
}

# ─── New ─────────────────────────────────────────────────────────────────────

cmd_new() {
    local kind="${1:-}"
    local name="${2:-}"

    [[ -z "$kind" ]] && error "Specify template type: pptex new slides <name>  or  pptex new report <name>"
    [[ -z "$name" ]] && error "Specify a project name: pptex new ${kind} <name>"

    local src dest_base
    case "$kind" in
        slides|presentation)
            src="${PPTEX_DIR}/templates/slides"
            dest_base="${PPTEX_DIR}/slides"
            ;;
        report|reports)
            src="${PPTEX_DIR}/templates/report"
            dest_base="${PPTEX_DIR}/reports"
            ;;
        *)
            error "Unknown template type '${kind}'. Use: slides | report"
            ;;
    esac

    mkdir -p "$dest_base"
    local dest="${dest_base}/${name}"
    [[ -d "$dest" ]] && error "Project already exists: ${dest}"

    cp -r "$src" "$dest"
    success "Created ${kind} project: ${dest}"
    info "Compile with:  pptex compile ${kind} ${name}"
    info "Watch with:    pptex watch ${kind} ${name}"
}

# ─── List ────────────────────────────────────────────────────────────────────

cmd_list() {
    local filter="${1:-all}"
    local found=false

    list_type() {
        local type="$1"
        local dir="${PPTEX_DIR}/${type}"

        echo -e "${BOLD}${type}/${NC}"
        if [[ ! -d "$dir" ]] || [[ -z "$(ls -A "$dir" 2>/dev/null)" ]]; then
            echo -e "  ${YELLOW}(no projects yet)${NC}"
            echo -e "  Create one: pptex new ${type%s} <name>"
        else
            for d in "${dir}"/*/; do
                [[ -d "$d" ]] || continue
                local pname
                pname="$(basename "$d")"
                local has_main=""
                [[ -f "${d}main.tex" ]] && has_main=" ${GREEN}✓${NC}" || has_main=" ${RED}no main.tex${NC}"
                echo -e "  ${pname}${has_main}"
                found=true
            done
        fi
        echo ""
    }

    case "$filter" in
        slides)  list_type "slides"  ;;
        reports) list_type "reports" ;;
        all)
            list_type "slides"
            list_type "reports"
            ;;
        *) error "Unknown type '${filter}'. Use: slides | reports | all" ;;
    esac
}

# ─── Clean ───────────────────────────────────────────────────────────────────

cmd_clean() {
    local positional=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*) error "Unknown option: $1" ;;
            *)  positional+=("$1"); shift  ;;
        esac
    done

    clean_dir() {
        local abs_dir="$1"
        info "Cleaning ${abs_dir} ..."
        docker run --rm \
            -v "${abs_dir}:/workspace" \
            -w /workspace \
            "${IMAGE_NAME}:${IMAGE_TAG}" \
            latexmk -C
    }

    ensure_image

    if [[ ${#positional[@]} -eq 2 ]]; then
        # pptex clean slides congreso
        local main
        main="$(resolve_project "${positional[0]}" "${positional[1]}")"
        clean_dir "$(dirname "$main")"
    elif [[ ${#positional[@]} -eq 1 ]]; then
        # pptex clean path/to/dir  or  pptex clean all
        if [[ "${positional[0]}" == "all" ]]; then
            clean_dir "${PPTEX_DIR}"
        else
            local abs_dir
            abs_dir="$(cd "${positional[0]}" && pwd)"
            clean_dir "$abs_dir"
        fi
    else
        # pptex clean → clean both slides/ and reports/
        clean_dir "${PPTEX_DIR}"
    fi

    success "Clean complete."
}

# ─── Shell ───────────────────────────────────────────────────────────────────

cmd_shell() {
    ensure_image
    info "Opening shell inside the LaTeX container (type 'exit' to leave)..."
    docker run --rm -it \
        -v "${PPTEX_DIR}:/workspace" \
        -w /workspace \
        "${IMAGE_NAME}:${IMAGE_TAG}" \
        bash
}

# ─── Entrypoint ──────────────────────────────────────────────────────────────

[[ $# -eq 0 ]] && usage && exit 0

command="${1}"; shift

case "$command" in
    compile)        cmd_compile "$@" ;;
    watch)          cmd_watch   "$@" ;;
    new)            cmd_new     "$@" ;;
    list)           cmd_list    "$@" ;;
    clean)          cmd_clean   "$@" ;;
    shell)          cmd_shell        ;;
    build)          build_image "$@" ;;
    -h|--help|help) usage            ;;
    *) error "Unknown command: ${command}. Run 'pptex help' for usage." ;;
esac
