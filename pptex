#!/usr/bin/env bash
set -euo pipefail

PPTEX_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_NAME="pptex"
IMAGE_TAG="latest"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${BLUE}[pptex]${NC} $*"; }
success() { echo -e "${GREEN}[pptex]${NC} $*"; }
warn()    { echo -e "${YELLOW}[pptex]${NC} $*"; }
error()   { echo -e "${RED}[pptex] Error:${NC} $*" >&2; exit 1; }

usage() {
    echo -e "${BOLD}pptex${NC} — LaTeX with Docker, zero friction"
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    echo "  pptex <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS${NC}"
    echo "  compile <file.tex>         Compile a LaTeX file to PDF"
    echo "  watch   <file.tex>         Watch and recompile on changes"
    echo "  new slides <name>          Create a new presentation from template"
    echo "  new report <name>          Create a new report from template"
    echo "  shell                      Open an interactive shell in the container"
    echo "  build                      Build (or rebuild) the Docker image"
    echo "  clean   [dir]              Remove LaTeX auxiliary files"
    echo ""
    echo -e "${BOLD}OPTIONS (compile / watch)${NC}"
    echo "  -e, --engine <engine>      pdflatex | xelatex | lualatex  (default: xelatex)"
    echo "  -b, --biber                Run biber for bibliography (biblatex)"
    echo "  -o, --output-dir <dir>     Output directory for the PDF (default: same as source)"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo "  pptex build"
    echo "  pptex new slides my-talk"
    echo "  pptex compile my-talk/main.tex"
    echo "  pptex compile my-talk/main.tex --engine lualatex --biber"
    echo "  pptex watch my-talk/main.tex"
    echo "  pptex clean my-talk/"
}

# ─── Image management ───────────────────────────────────────────────────────

build_image() {
    info "Building Docker image ${IMAGE_NAME}:${IMAGE_TAG} ..."
    docker build -t "${IMAGE_NAME}:${IMAGE_TAG}" "${PPTEX_DIR}"
    success "Image built successfully."
}

ensure_image() {
    if ! docker image inspect "${IMAGE_NAME}:${IMAGE_TAG}" &>/dev/null; then
        warn "Docker image not found. Building it now (first time only — this may take a few minutes)..."
        build_image
    fi
}

# ─── Compile ────────────────────────────────────────────────────────────────

cmd_compile() {
    local file=""
    local engine="xelatex"
    local use_biber=false
    local output_dir=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -e|--engine)    engine="$2";     shift 2 ;;
            -b|--biber)     use_biber=true;  shift   ;;
            -o|--output-dir) output_dir="$2"; shift 2 ;;
            -*)             error "Unknown option: $1" ;;
            *)              file="$1";       shift   ;;
        esac
    done

    [[ -z "$file" ]] && error "No .tex file specified. Usage: pptex compile <file.tex>"
    [[ ! -f "$file" ]] && error "File not found: $file"

    local abs_file
    abs_file="$(cd "$(dirname "$file")" && pwd)/$(basename "$file")"
    local src_dir
    src_dir="$(dirname "$abs_file")"
    local basename
    basename="$(basename "$abs_file" .tex)"

    local out_dir="${output_dir:-$src_dir}"
    [[ "$output_dir" ]] && mkdir -p "$out_dir" && out_dir="$(cd "$out_dir" && pwd)"

    local latexmk_args=("-${engine}" "-interaction=nonstopmode" "-file-line-error" "-synctex=1")
    [[ "$use_biber" == true ]] && latexmk_args+=("-biber")
    [[ "$out_dir" != "$src_dir" ]] && latexmk_args+=("-outdir=/out")

    ensure_image

    info "Compiling ${basename}.tex with ${engine}${use_biber:+ + biber}..."

    local docker_cmd="latexmk ${latexmk_args[*]} '${basename}.tex'"

    if [[ "$out_dir" != "$src_dir" ]]; then
        docker run --rm \
            -v "${src_dir}:/workspace" \
            -v "${out_dir}:/out" \
            -w /workspace \
            "${IMAGE_NAME}:${IMAGE_TAG}" \
            bash -c "$docker_cmd"
    else
        docker run --rm \
            -v "${src_dir}:/workspace" \
            -w /workspace \
            "${IMAGE_NAME}:${IMAGE_TAG}" \
            bash -c "$docker_cmd"
    fi

    success "Done! PDF: ${out_dir}/${basename}.pdf"
}

# ─── Watch ──────────────────────────────────────────────────────────────────

cmd_watch() {
    local file=""
    local engine="xelatex"
    local use_biber=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -e|--engine)  engine="$2";    shift 2 ;;
            -b|--biber)   use_biber=true; shift   ;;
            -*)           error "Unknown option: $1" ;;
            *)            file="$1";      shift   ;;
        esac
    done

    [[ -z "$file" ]] && error "No .tex file specified. Usage: pptex watch <file.tex>"
    [[ ! -f "$file" ]] && error "File not found: $file"

    local abs_file
    abs_file="$(cd "$(dirname "$file")" && pwd)/$(basename "$file")"
    local src_dir
    src_dir="$(dirname "$abs_file")"
    local basename
    basename="$(basename "$abs_file" .tex)"

    local latexmk_args=("-${engine}" "-interaction=nonstopmode" "-pvc" "-synctex=1")
    [[ "$use_biber" == true ]] && latexmk_args+=("-biber")

    ensure_image

    info "Watching ${basename}.tex (press Ctrl+C to stop)..."

    docker run --rm -it \
        -v "${src_dir}:/workspace" \
        -w /workspace \
        "${IMAGE_NAME}:${IMAGE_TAG}" \
        latexmk "${latexmk_args[@]}" "${basename}.tex"
}

# ─── New ────────────────────────────────────────────────────────────────────

cmd_new() {
    local kind="${1:-}"
    local name="${2:-}"

    [[ -z "$kind" ]] && error "Specify template type: pptex new slides <name>  or  pptex new report <name>"
    [[ -z "$name" ]] && error "Specify a project name: pptex new ${kind} <name>"

    case "$kind" in
        slides|presentation)
            local src="${PPTEX_DIR}/templates/slides"
            ;;
        report)
            local src="${PPTEX_DIR}/templates/report"
            ;;
        *)
            error "Unknown template type '${kind}'. Use: slides | report"
            ;;
    esac

    local dest="${PWD}/${name}"
    [[ -d "$dest" ]] && error "Directory already exists: ${dest}"

    cp -r "$src" "$dest"
    success "Created ${kind} project at: ${dest}"
    info "Compile with: pptex compile ${name}/main.tex"
}

# ─── Shell ──────────────────────────────────────────────────────────────────

cmd_shell() {
    ensure_image
    info "Opening shell inside the LaTeX container (type 'exit' to leave)..."
    docker run --rm -it \
        -v "${PWD}:/workspace" \
        -w /workspace \
        "${IMAGE_NAME}:${IMAGE_TAG}" \
        bash
}

# ─── Clean ──────────────────────────────────────────────────────────────────

cmd_clean() {
    local dir="${1:-.}"
    [[ ! -d "$dir" ]] && error "Directory not found: $dir"

    local abs_dir
    abs_dir="$(cd "$dir" && pwd)"

    info "Cleaning auxiliary files in ${abs_dir} ..."
    docker run --rm \
        -v "${abs_dir}:/workspace" \
        -w /workspace \
        "${IMAGE_NAME}:${IMAGE_TAG}" \
        latexmk -C

    success "Clean complete."
}

# ─── Entrypoint ─────────────────────────────────────────────────────────────

[[ $# -eq 0 ]] && usage && exit 0

command="${1}"; shift

case "$command" in
    compile)  cmd_compile "$@" ;;
    watch)    cmd_watch   "$@" ;;
    new)      cmd_new     "$@" ;;
    shell)    cmd_shell        ;;
    build)    build_image      ;;
    clean)    cmd_clean   "$@" ;;
    -h|--help|help) usage      ;;
    *) error "Unknown command: ${command}. Run 'pptex help' for usage." ;;
esac
